<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Simple Email</title>
  </head>
  <body style="background-color: #f5f5f5; padding: 20px; border-radius: 10px">
    <div>
      <h1 style="color: #4caf50; margin-bottom: 20px"><%= subject %></h1>
      <p style="color: #666; margin-bottom: 20px"><%= body %></p>
    </div>
  </body>
  <style>
    body {
      font-family: Arial, sans-serif;
      color: #333;
      font-size: 16px;
      line-height: 1.5;
      font-weight: 400;
      background-color: #fff;
      margin: 0;
      padding: 20px;
    }
    h1 {
      color: #000;
    }
    p {
      color: #666;
    }
  </style>
</html>
